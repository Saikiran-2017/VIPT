# ─── Server ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vipt_price_tracker
DB_USER=vipt_admin
DB_PASSWORD=vipt_secure_password_2026

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── API Keys ──────────────────────────────────────
# Add your affiliate API keys here
AMAZON_API_KEY=
AMAZON_API_SECRET=
WALMART_API_KEY=
EBAY_API_KEY=

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=debug

# ─── CORS ──────────────────────────────────────────
CORS_ORIGIN=chrome-extension://*
