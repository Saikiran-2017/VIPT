# ─── Server ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────────────
# Production / PaaS: set DATABASE_URL (takes precedence over DB_*).
# Example: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5433
DB_NAME=vipt_price_tracker
DB_USER=vipt_admin
DB_PASSWORD=vipt_secure_password_2026

# ─── Redis ──────────────────────────────────────────
# Production / PaaS: set REDIS_URL (takes precedence over REDIS_HOST/PORT/PASSWORD).
# Examples: redis://localhost:6379  |  rediss://user:pass@host:6379
REDIS_URL=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Database migrations ────────────────────────────
# Set to 1 to skip migrations on boot (e.g. when you run db:migrate in a release phase).
# Default: migrations run on startup when the DB is reachable.
SKIP_DB_MIGRATE=

# ─── API Keys ──────────────────────────────────────
# Add your affiliate API keys here
AMAZON_API_KEY=
AMAZON_API_SECRET=
WALMART_API_KEY=
EBAY_API_KEY=

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=debug

# ─── CORS ──────────────────────────────────────────
# Production: set to your web app origin(s), comma-separated if needed.
CORS_ORIGIN=chrome-extension://*
